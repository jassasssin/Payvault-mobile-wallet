# ─── Copy this to .env and fill values before running docker-compose ──────────

# JWT
JWT_SECRET=replace-with-random-256-bit-secret

# App
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Grafana
GRAFANA_PASSWORD=admin123

# Vault
VAULT_TOKEN=root-dev-token

# Notification (optional – leave blank for stub mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@payvault.com
